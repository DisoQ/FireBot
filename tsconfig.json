{
  "compilerOptions": {
    "target": "ESNext",
    "module": "nodenext",
    "strict": false,
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "outDir": "dist/",
    "paths": {
      "@fire/lib/*": ["./lib/*"],
      "@fire/src/*": ["./src/*"],
      "@fire/config/*": ["./config/*"],
      "@fire/i18n/*": ["./languages/*"]
    }
  },
  "exclude": [
    "node_modules",
    "./node_modules",
    "./node_modules/*",
    "./node_modules/@types/node/index.d.ts"
  ]
}
